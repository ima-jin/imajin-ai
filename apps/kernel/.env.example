# =============================================================================
# Kernel — consolidated env for all kernel services
# (www, auth, pay, profile, registry, connections, chat, media, notify)
# =============================================================================

NODE_ENV=production
IMAJIN_ENV=dev
PORT=3000

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/imajin_dev"

# --- Auth ---
AUTH_PRIVATE_KEY=""
ATTESTATION_INTERNAL_API_KEY=""
AUTH_INTERNAL_API_KEY=""
GROUP_KEY_ENCRYPTION_SECRET=""
ADMIN_DID=did:imajin:your-admin-did

# --- Stripe (Pay) ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""
EVENTS_WEBHOOK_SECRET=""
COFFEE_WEBHOOK_SECRET=""
PAY_SERVICE_API_KEY=""
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
PLATFORM_DID=did:imajin:platform
PLATFORM_FEE_PERCENT=0.2

# --- Email (SendGrid) ---
SENDGRID_API_KEY=""
SENDGRID_FROM="Name <email@example.com>"
SENDGRID_FROM_EMAIL=notifications@example.com

# --- Media ---
MEDIA_ROOT=/mnt/media
MEDIA_INTERNAL_API_KEY=""
GPU_NODE_URL=http://localhost:8765
GPU_AUTH_TOKEN=

# --- AI/Inference ---
ANTHROPIC_API_KEY=""
OLLAMA_BASE_URL=http://localhost:11434

# --- Notify ---
NOTIFY_WEBHOOK_SECRET=""
UNSUBSCRIBE_HMAC_SECRET=""

# --- Registry / Relay ---
RELAY_STORE=postgres
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""
CLOUDFLARE_BASE_DOMAIN="imajin.ai"
TRUST_INTERNAL_API_KEY=""

# --- GitHub ---
GITHUB_REPO=ima-jin/imajin-ai
GITHUB_TOKEN=""

# --- Internal service URLs (kernel self-references) ---
AUTH_SERVICE_URL=http://localhost:3000/auth
AUTH_INTERNAL_URL=http://localhost:3000/auth
CONNECTIONS_SERVICE_URL=http://localhost:3000/connections
CONNECTIONS_URL=http://localhost:3000/connections
PROFILE_SERVICE_URL=http://localhost:3000/profile
PAY_SERVICE_URL=http://localhost:3000/pay
CHAT_SERVICE_URL=http://localhost:3000/chat
MEDIA_SERVICE_URL=http://localhost:3000/media
NOTIFY_SERVICE_URL=http://localhost:3000/notify
REGISTRY_URL=http://localhost:3000/registry

# --- Userspace service URLs ---
EVENTS_SERVICE_URL=http://localhost:3006
EVENTS_URL=https://your-node.imajin.ai/events
COFFEE_SERVICE_URL=http://localhost:3100
LINKS_SERVICE_URL=http://localhost:3102
DYKIL_SERVICE_URL=http://localhost:3101
LEARN_SERVICE_URL=http://localhost:3103

# --- Public URLs (client-side, update for your node domain) ---
NEXT_PUBLIC_SERVICE_PREFIX=https://your-node.imajin.ai/
NEXT_PUBLIC_DOMAIN=imajin.ai
NEXT_PUBLIC_DISABLE_INVITE_GATE=true
NEXT_PUBLIC_AUTH_URL=https://your-node.imajin.ai/auth
NEXT_PUBLIC_WWW_URL=https://your-node.imajin.ai
NEXT_PUBLIC_CHAT_URL=https://your-node.imajin.ai/chat
NEXT_PUBLIC_CONNECTIONS_URL=https://your-node.imajin.ai/connections
NEXT_PUBLIC_EVENTS_URL=https://your-node.imajin.ai/events
NEXT_PUBLIC_PAY_URL=https://your-node.imajin.ai/pay
NEXT_PUBLIC_PROFILE_URL=https://your-node.imajin.ai/profile
NEXT_PUBLIC_REGISTRY_URL=https://your-node.imajin.ai/registry
NEXT_PUBLIC_COFFEE_URL=https://your-node.imajin.ai/coffee
NEXT_PUBLIC_DYKIL_URL=https://your-node.imajin.ai/dykil
NEXT_PUBLIC_LINKS_URL=https://your-node.imajin.ai/links
NEXT_PUBLIC_LEARN_URL=https://your-node.imajin.ai/learn
NEXT_PUBLIC_MARKET_URL=https://your-node.imajin.ai/market
NEXT_PUBLIC_MEDIA_SERVICE_URL=https://your-node.imajin.ai/media
NEXT_PUBLIC_MEDIA_URL=https://your-node.imajin.ai/media
NEXT_PUBLIC_NOTIFY_URL=https://your-node.imajin.ai/notify
NEXT_PUBLIC_BASE_URL=https://your-node.imajin.ai
NEXT_PUBLIC_APP_URL=https://your-node.imajin.ai/chat
