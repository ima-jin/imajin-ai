# Registry Service

# Database
DATABASE_URL=postgres://user:password@localhost:5432/imajin_dev

# App
PORT=3002
IMAJIN_ENV=dev

# Cloudflare (for subdomain provisioning)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_BASE_DOMAIN=imajin.ai

# Service URLs (internal — spec proxy)
AUTH_SERVICE_URL=http://localhost:3001
PAY_SERVICE_URL=http://localhost:3004
PROFILE_SERVICE_URL=http://localhost:3005
EVENTS_SERVICE_URL=http://localhost:3006
CHAT_SERVICE_URL=http://localhost:3007
CONNECTIONS_SERVICE_URL=http://localhost:3003
COFFEE_SERVICE_URL=http://localhost:3100
LINKS_SERVICE_URL=http://localhost:3102
DYKIL_SERVICE_URL=http://localhost:3101
MEDIA_SERVICE_URL=http://localhost:3009
INPUT_SERVICE_URL=http://localhost:3008
LEARN_SERVICE_URL=http://localhost:3103

# Public URLs (client-side)
NEXT_PUBLIC_DOMAIN=imajin.ai
# http://localhost: for local dev, https://dev- for deployed dev, https:// for prod
NEXT_PUBLIC_SERVICE_PREFIX=http://localhost:

# DFOS Relay
RELAY_DID=did:imajin:relay-dev
RELAY_STORE=postgres

# Runtime
NODE_ENV=
