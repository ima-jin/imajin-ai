# Market Service

# Database
DATABASE_URL=postgres://user:password@localhost:5432/imajin_dev

# Service URLs (internal)
AUTH_SERVICE_URL=http://localhost:3001
PAY_SERVICE_URL=http://localhost:3004
PROFILE_SERVICE_URL=http://localhost:3005
MEDIA_SERVICE_URL=http://localhost:3009

# Webhooks (unused — market routes through pay, but env check requires it)
WEBHOOK_SECRET=

# Public URLs (client-side)
NEXT_PUBLIC_BASE_URL=http://localhost:3104
NEXT_PUBLIC_DOMAIN=imajin.ai
# http://localhost: for local dev, https://dev- for deployed dev, https:// for prod
NEXT_PUBLIC_SERVICE_PREFIX=http://localhost:
NEXT_PUBLIC_MEDIA_URL=https://dev-media.imajin.ai

# Runtime
PORT=
NODE_ENV=
IMAJIN_ENV=dev

# Internal API key for attestation emission (must match kernel)
ATTESTATION_INTERNAL_API_KEY=""
