# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API key for LLM routing
ANTHROPIC_API_KEY=

# Kernel API base URL (no trailing slash)
KERNEL_URL=https://jin.imajin.ai

# Bot's registered Imajin app DID and short-lived bearer token
# Generate via: POST /api/apps/token with the bot's keypair
BOT_APP_TOKEN=

# Optional: how often to poll for pending match notifications (ms, default 30000)
MATCH_POLL_INTERVAL_MS=30000
