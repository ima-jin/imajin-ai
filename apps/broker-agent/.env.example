# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API key for LLM routing
ANTHROPIC_API_KEY=

# Kernel API base URL (no trailing slash)
KERNEL_URL=https://jin.imajin.ai

# Bot's registered Imajin app DID and Ed25519 private key (raw 32-byte hex seed)
# The agent self-mints a short-lived service token at startup using the keypair.
# Register the app via POST /auth/api/apps and use the returned DID + private key.
APP_DID=
APP_PRIVATE_KEY=

# Optional: how often to poll for pending match notifications (ms, default 30000)
MATCH_POLL_INTERVAL_MS=30000
