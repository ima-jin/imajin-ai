# Auth Service

# Database
DATABASE_URL=postgres://user:password@localhost:5432/imajin_dev

# Auth
AUTH_PRIVATE_KEY=your-ed25519-private-key-hex

# Service URLs (internal)
AUTH_SERVICE_URL=http://localhost:3001
CONNECTIONS_SERVICE_URL=http://localhost:3003
REGISTRY_URL=http://localhost:3002
EVENTS_SERVICE_URL=http://localhost:3006
EVENTS_URL=http://localhost:3006
PROFILE_SERVICE_URL=http://localhost:3005

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM=Jin <jin@imajin.ai>

# Public URLs (client-side)
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN=imajin.ai
# http://localhost: for local dev, https://dev- for deployed dev, https:// for prod
NEXT_PUBLIC_SERVICE_PREFIX=http://localhost:

# Internal service auth
ATTESTATION_INTERNAL_API_KEY=your-attestation-internal-api-key

# Feature flags
# Set to true for local dev (lets you register without an invite code)
NEXT_PUBLIC_DISABLE_INVITE_GATE=true

# Runtime
PORT=
NODE_ENV=

# Notify service auth (must match NOTIFY_WEBHOOK_SECRET in notify service)
NOTIFY_WEBHOOK_SECRET=dev-secret-change-me

# Group identity encryption (server-side key for group private keys)
GROUP_KEY_ENCRYPTION_SECRET=change-me-in-production
