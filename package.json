{
  "name": "imajin-ai",
  "version": "0.6.1",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:migrate": "node scripts/migrate.mjs",
    "sonar:baseline": "powershell -ExecutionPolicy Bypass -File scripts/sonar/phase1-capture-baseline.ps1",
    "sonar:legacy-review": "powershell -ExecutionPolicy Bypass -File scripts/sonar/phase15-legacy-debt-review.ps1",
    "sonar:batch": "node scripts/sonar/phase16-next-batch.mjs",
    "sonar:rip": "pnpm sonar:legacy-review && pnpm sonar:batch -- --lane A --size 10",
    "generate:api-specs": "tsx scripts/generate-api-specs.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint": "^8",
    "eslint-config-next": "14",
    "husky": "^9.1.7",
    "next": "^14.2.0",
    "postgres": "^3.4.5",
    "tsx": "^4.21.0",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@metalabel/dfos-protocol": "^0.7.0",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.7.2",
    "bs58": "^6.0.0",
    "sharp": "^0.34.5"
  }
}
